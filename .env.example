# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is read by the Express server and should never be exposed in the browser.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TBA_API_KEY: Required for The Blue Alliance API calls.
# This is read by the Express server and should never be exposed in the browser.
TBA_API_KEY="MY_TBA_API_KEY"

# Optional server port override.
PORT=3000

# Supabase project URL and service-role key for backend database access.
# Keep the service-role key server-only and never expose it in browser code.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
