# Frontend env vars for Vercel deployment.
# Prefix with VITE_ so Vite can expose them to browser code.

# Supabase client credentials
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_publishable_or_anon_key"

# Server-side key for Vercel Function proxying TBA requests
TBA_API_KEY="your_tba_api_key"

# Server-side key for Vercel Function Gemini analysis
GEMINI_API_KEY="your_gemini_api_key"
